<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!--
        MoveIt FakeSystem for KAAIR-specific joints only.

        Arm joints (joint1–joint7) are intentionally excluded here.
        They are provided by UFRobotFakeSystemHardware inside robot.urdf.xacro
        when use_fake_hardware=true, so claiming them again would cause a
        ros2_control ResourceManager conflict.

        Covered joints:
          - lift_joint          (LiftHwInterface in real mode)
          - head_joint1/2       (HeadHwInterface in real mode)
          - virtual_gripper_joint (ToolHwInterface in real mode)
    -->
    <xacro:macro name="kaair_ros2_control" params="name initial_positions_file">
        <xacro:property name="initial_positions" value="${load_yaml(initial_positions_file)['initial_positions']}"/>

        <ros2_control name="${name}" type="system">
            <hardware>
                <plugin>mock_components/GenericSystem</plugin>
            </hardware>

            <joint name="lift_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['lift_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>

            <joint name="head_joint1">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['head_joint1']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>

            <joint name="head_joint2">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['head_joint2']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>

            <joint name="virtual_gripper_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['virtual_gripper_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>

        </ros2_control>
    </xacro:macro>
</robot>
